// ── CORE ──────────────────────────────────────────────────────────────────────

model Company {
  id                       String             @id @default(uuid())
  name                     String
  email                    String?            @unique
  phone                    String?
  address                  String?
  website                  String?
  industry                 String?
  slug                     String?            @unique
  plan                     Plan               @default(Free)
  subscriptionStatus       SubscriptionStatus @default(Active)
  subscriptionStartDate    DateTime?
  subscriptionEndDate      DateTime?
  trialEndDate             DateTime?
  billingCycle             BillingCycle?      @default(Monthly)
  customFieldsSectionTitle String?            @default("Custom Fields")
  metaAppId                String?
  metaAppSecret            String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  branches             Branch[]
  users                User[]
  cuttingOrders        CuttingOrder[]
  leadStages           LeadStage[]
  documentStages       DocumentStage[]
  invoiceStages        InvoiceStage[]
  estimateStages       EstimateStage[]
  sources              Source[]
  contactTypes         ContactType[]
  salutations          Salutation[]
  callStatuses         CallStatus[]
  companyTypes         CompanyType[]
  employees            Employee[]
  industries           Industry[]
  dealTypes            DealType[]
  currencies           Currency[]
  locations            Location[]
  taxes                Tax[]
  unitsOfMeasurement   UnitOfMeasurement[]
  productProperties    ProductProperty[]
  dealPipelines        DealPipeline[]
  crmRoles             CrmRole[]
  accessControls       AccessControl[]
  securities           Security[]
  permissionSettings   PermissionSetting[]
  businessProcesses    BusinessProcess[]
  emailTemplates       EmailTemplate[]
  smtpSettings         SmtpSetting[]
  emailNotifications   EmailNotification[]
  emailSignatures      EmailSignature[]
  formTemplates        FormTemplate[]
  entityData           EntityData[]
  customEntityPages    CustomEntityPage[]
  feedPosts            FeedPost[]
  collabs              Collab[]
  workGroups           WorkGroup[]
  richDocuments        RichDocument[]
  calendarEvents       CalendarEvent[]
  fitnessActivities    FitnessActivity[]
  nutritionEntries     NutritionEntry[]
  sleepRecords         SleepRecord[]
  products             Product[]
  productCategories    ProductCategory[]
  productSubCategories ProductSubCategory[]
  customers            Customer[]
  orders               Order[]
  folders              Folder[]
  mediaFiles           MediaFile[]
  projects             Project[]
  menuItems            MenuItem[]
  chats                Chat[]
  formSections         FormSection[]
  formSectionPerms     FormSectionPermission[]
  formFieldPerms       FormFieldPermission[]
  mails                Mail[]
  chatAccess           ChatAccess[]
  customFields         CustomField[]
  analyticalReports    AnalyticalReport[]
  autoNumberings       AutoNumbering[]
  reminders            Reminder[]
  customerPayments     CustomerPayment[]
  supplierPayments     SupplierPayment[]
  suppliers            Supplier[]
  orderReturns         OrderReturn[]
  tableCategories      TableCategory[]
  restaurantTables     RestaurantTable[]
  reportTemplates      ReportTemplate[]
  pdfReports           PdfReport[]
  dealDashboards       DealDashboard[]
  loginHistory         LoginHistory[]
  storageQuotas        StorageQuota[]
  systemSettings       SystemSetting[]
  exceptionLogs        ExceptionLog[]
  activities           Activity[]
  comments             Comment[]
  pricingPlans         PricingPlan[]
}

