  changedBy    String
  notes        String?
  createdAt    DateTime @default(now())

  sampleCard SampleCard @relation(fields: [sampleCardId], references: [id], onDelete: Cascade)
}

// ── PLM — Templates ───────────────────────────────────────────────────────────

model PlmTemplate {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  structure   Json
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  branchId    String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── PLM — Orders & Tasks ──────────────────────────────────────────────────────

model PlmOrder {
  id            String    @id @default(uuid())
  orderNumber   String    @unique
  styleCardId   String
  productCardId String?
  buyerName     String?
  quantity      Int
  sizes         Json?
  deliveryDate  DateTime?
  status        String    @default("pending")
  totalCost     Decimal?  @db.Decimal(12, 2)
  currency      String    @default("PKR")
  notes         String?
  branchId      String
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  styleCard StyleCard @relation(fields: [styleCardId], references: [id])
  tasks     PlmTask[]
  orderType String    @default("local")
}

model PlmTask {
  id           String    @id @default(uuid())
  taskNumber   String    @unique
  plmOrderId   String?
  styleCardId  String?
  bpmTaskId    String?
  title        String
  description  String?
  taskType     String
  assignedTo   String?
  departmentId String?
  priority     String    @default("medium")
  status       String    @default("pending")
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  estimatedHrs Decimal?  @db.Decimal(8, 2)
  actualHrs    Decimal?  @db.Decimal(8, 2)
  notes        String?
  branchId     String
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  plmOrder  PlmOrder?  @relation(fields: [plmOrderId], references: [id])
  styleCard StyleCard? @relation(fields: [styleCardId], references: [id])
}

// ── PLM — Critical Path ───────────────────────────────────────────────────────

model CriticalPath {
  id          String   @id @default(uuid())
  styleCardId String   @unique
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active")
  createdAt   DateTime @default(now())

  styleCard StyleCard          @relation(fields: [styleCardId], references: [id])
  tasks     CriticalPathTask[]
}

model CriticalPathTask {
  id             String    @id @default(uuid())
  criticalPathId String
  processCardId  String?
  title          String
  sequence       Int
  durationDays   Int
  plannedStart   DateTime
  plannedEnd     DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  dependsOn      Json?
  assignedTo     String?
  departmentId   String?
  status         String    @default("pending")
  isCritical     Boolean   @default(false)
  delayDays      Int?
  notes          String?

  criticalPath CriticalPath @relation(fields: [criticalPathId], references: [id], onDelete: Cascade)
  processCard  ProcessCard? @relation(fields: [processCardId], references: [id])
}

// ── PLM — Document Management ─────────────────────────────────────────────────

model PlmDocument {
  id             String   @id @default(uuid())
  title          String
  documentNumber String   @unique
  entityType     String
  entityId       String
  category       String
  fileUrl        String
  fileName       String
  fileType       String
  fileSize       Int?
  version        String   @default("1.0")
  isLatest       Boolean  @default(true)
  uploadedBy     String
  branchId       String
  createdAt      DateTime @default(now())
}

// ══════════════════════════════════════════════════════════
// DOCKET MANAGEMENT MODULE
// ══════════════════════════════════════════════════════════

model DocumentTypeCard {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  category         String
  description      String?
  allowedFormats   Json
  maxSizeMb        Int      @default(10)
  requiresApproval Boolean  @default(true)
  expiryDays       Int?
  isActive         Boolean  @default(true)
  branchId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  docketTemplateItems DocketTemplateItem[]
  docketItems         DocketItem[]

  @@index([category])
  @@index([isActive])
}

model DocketTemplate {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  entityType  String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  branchId    String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items   DocketTemplateItem[]
  dockets Docket[]

  @@index([entityType])
  @@index([isDefault])
}

model DocketTemplateItem {
  id                 String   @id @default(uuid())
  templateId         String
  documentTypeCardId String
  isRequired         Boolean  @default(true)
  sequence           Int      @default(0)
  defaultDueDays     Int?
  approvalRequired   Boolean  @default(true)
  approverRoleId     String?
  notes              String?

  template         DocketTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  documentTypeCard DocumentTypeCard  @relation(fields: [documentTypeCardId], references: [id])

  @@index([templateId])
}

model ApprovalWorkflow {
  id         String   @id @default(uuid())
  name       String
  entityType String
  steps      Json
  isActive   Boolean  @default(true)
  branchId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType])
}

model Docket {
  id            String    @id @default(uuid())
  docketNumber  String    @unique
  entityType    String
  entityId      String
  templateId    String?
  title         String
  status        String    @default("incomplete")
  completeness  Decimal   @default(0) @db.Decimal(5, 2)
  totalItems    Int       @default(0)
  approvedItems Int       @default(0)
  pendingItems  Int       @default(0)
  missingItems  Int       @default(0)
  lockedAt      DateTime?
  lockedBy      String?
  approvedAt    DateTime?
  approvedBy    String?
  branchId      String
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  template   DocketTemplate?  @relation(fields: [templateId], references: [id])
  items      DocketItem[]
  shareLinks DocketShareLink[]
  auditLogs  DocketAuditLog[]

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([status])
  @@index([branchId])
}

model DocketItem {
  id                 String    @id @default(uuid())
  docketId           String
  documentTypeCardId String
  title              String
  isRequired         Boolean   @default(true)
  sequence           Int       @default(0)
  status             String    @default("missing")
  currentVersion     String?
  approvedBy         String?
  approvedAt         DateTime?
  rejectedBy         String?
  rejectedAt         DateTime?
  rejectionReason    String?
  dueDate            DateTime?
  expiryDate         DateTime?
  notes              String?

  docket           Docket          @relation(fields: [docketId], references: [id], onDelete: Cascade)
  documentTypeCard DocumentTypeCard @relation(fields: [documentTypeCardId], references: [id])
  documents        DocketDocument[]
  approvalHistory  DocketItemApproval[]

  @@index([docketId])
  @@index([status])
}

model DocketDocument {
  id             String   @id @default(uuid())
  documentNumber String   @unique
  docketItemId   String
  fileName       String
  fileUrl        String
  fileType       String
  fileSizeMb     Decimal  @db.Decimal(8, 2)
  version        String
  versionNotes   String?
  isLatest       Boolean  @default(true)
  isWatermarked  Boolean  @default(false)
  watermarkedUrl String?
  uploadedBy     String
  uploadedAt     DateTime @default(now())

  docketItem DocketItem @relation(fields: [docketItemId], references: [id], onDelete: Cascade)

  @@index([docketItemId])
  @@index([isLatest])
}

model DocketItemApproval {
  id              String   @id @default(uuid())
  docketItemId    String
  action          String
  actionBy        String
  fromStatus      String?
  toStatus        String
  comments        String?
  documentVersion String?
  createdAt       DateTime @default(now())

  docketItem DocketItem @relation(fields: [docketItemId], references: [id], onDelete: Cascade)

  @@index([docketItemId])
}

model DocketShareLink {
  id             String    @id @default(uuid())
  docketId       String
  token          String    @unique
  title          String?
  accessType     String    @default("view")
  sharedWith     String?
  sharedBy       String
  expiresAt      DateTime
  isActive       Boolean   @default(true)
  lastAccessedAt DateTime?
  accessCount    Int       @default(0)
  allowedItems   Json?
  password       String?
  watermark      Boolean   @default(true)
  createdAt      DateTime  @default(now())

  docket     Docket               @relation(fields: [docketId], references: [id], onDelete: Cascade)
  accessLogs ShareLinkAccessLog[]

  @@index([token])
  @@index([docketId])
}

model ShareLinkAccessLog {
  id          String   @id @default(uuid())
  shareLinkId String
  accessedAt  DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  action      String
  documentId  String?

  shareLink DocketShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@index([shareLinkId])
}

model ExternalReviewRequest {
  id              String    @id @default(uuid())
  docketId        String
  reviewerEmail   String
  reviewerName    String?
  reviewerCompany String?
  message         String?
  token           String    @unique
  status          String    @default("pending")
  expiresAt       DateTime
  comments        String?
  reviewedAt      DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())

  @@index([token])
  @@index([docketId])
}

model DocketAuditLog {
  id        String   @id @default(uuid())
  docketId  String
  action    String
  entityRef String?
  changedBy String
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())

  docket Docket @relation(fields: [docketId], references: [id], onDelete: Cascade)

  @@index([docketId])
}
