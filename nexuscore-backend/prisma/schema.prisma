model User {
  id                 String       @id @default(uuid())
  companyId          String
  branchId           String?
  name               String
  email              String       @unique
  password           String
  googleId           String?      @unique
  mustChangePassword Boolean      @default(true)
  country            String?
  crmRole            CrmUserRole?
  image              String?
  userStatus         UserStatus?  @default(active)
  planName           Plan?
  phone              String?
  location           String?
  department         String?
  hourlyRate         Decimal?     @db.Decimal(10, 2)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  company                  Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch                   Branch?                  @relation(fields: [branchId], references: [id])
  userRoles                UserRole[]
  bpmTasks                 BpmTask[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  cuttingBatches           CuttingBatch[]
  notes                    Note[]
  noteLabels               NoteLabel[]
  todos                    Todo[]
  settings                 UserSettings?
  passwordResetTokens      PasswordResetToken[]
  emailSignatures          EmailSignature[]
  feedPosts                FeedPost[]
  feedLikes                FeedLike[]
  feedComments             FeedComment[]
  createdCollabs           Collab[]                 @relation("CreatedCollabs")
  collabMembers            CollabMember[]
  collabInvitations        CollabInvitation[]       @relation("InvitedBy")
  createdWorkGroups        WorkGroup[]              @relation("CreatedWorkGroups")
  workGroupMembers         WorkGroupMember[]
  createdRichDocuments     RichDocument[]
  calendarEvents           CalendarEvent[]
  managedProjects          Project[]                @relation("ManagedProjects")
  projectMembers           ProjectMember[]
  reminders                Reminder[]
  fitnessActivities        FitnessActivity[]
  nutritionEntries         NutritionEntry[]
  sleepRecords             SleepRecord[]
  folders                  Folder[]
  mediaFiles               MediaFile[]
  connectionsAsUser1       UserConnection[]         @relation("User1Connections")
  connectionsAsUser2       UserConnection[]         @relation("User2Connections")
  createdProducts          Product[]                @relation("CreatedProducts")
  updatedProducts          Product[]                @relation("UpdatedProducts")
  createdReportTemplates   ReportTemplate[]         @relation("CreatedReportTemplates")
  updatedReportTemplates   ReportTemplate[]         @relation("UpdatedReportTemplates")
  createdPdfReports        PdfReport[]              @relation("CreatedPdfReports")
  updatedPdfReports        PdfReport[]              @relation("UpdatedPdfReports")
  createdDealDashboards    DealDashboard[]          @relation("CreatedDealDashboards")
  dealDashboardUserShares  DealDashboardUserShare[]
  dealDashboardPrefs       DealDashboardUserPref[]
  chatParticipants         ChatParticipant[]
  chatMessages             ChatMessage[]            @relation("SentMessages")
  formSectionPerms         FormSectionPermission[]
  formFieldPerms           FormFieldPermission[]
  mails                    Mail[]
  chatAccessGranted        ChatAccess[]             @relation("ChatAccessGranted")
  chatAccessReceived       ChatAccess[]             @relation("ChatAccessReceived")
  loginHistory             LoginHistory[]
  exceptionLogs            ExceptionLog[]
  processedReturns         OrderReturn[]            @relation("ProcessedReturns")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String  @id @default(uuid())
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId     String
  roleId     String
  assignedBy String?
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ── CRM LOOKUP TABLES ─────────────────────────────────────────────────────────

model LeadStage {
  id        String        @id @default(uuid())
  name      String
  color     String
  order     Int
  type      LeadStageType
  companyId String?
  branchId  String?
  company   Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([companyId])
  @@index([branchId])
}

