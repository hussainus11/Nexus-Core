# Application
PORT=3000
NODE_ENV=development

# Database
NEXUSCORE_DATABASE_URL=postgresql://postgres:password@localhost:5432/nexuscore_db

# JWT
NEXUSCORE_JWT_SECRET=change-me-in-production-very-long-secret-key
NEXUSCORE_JWT_EXPIRES_IN=7d
NEXUSCORE_JWT_REFRESH_SECRET=change-me-refresh-secret-very-long
NEXUSCORE_JWT_REFRESH_EXPIRES_IN=30d
NEXUSCORE_JWT_ISSUER=nexuscore

# RabbitMQ
NEXUSCORE_RABBITMQ_URL=amqp://guest:guest@localhost:5672
NEXUSCORE_RABBITMQ_EXCHANGE=nexuscore.events

# WhatsApp / Meta
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v17.0

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
